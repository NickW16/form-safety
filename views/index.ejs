<!DOCTYPE html>
<html lang="en">
<head>
   <meta charset="UTF-8">
   <title><%= title %></title>
</head>
<body>
   <h1><%= title %></h1>
   <form action="/search" method="GET">
      <input type="text" name="search" id="searchField" value="<%= locals.searchTerm || '' %>" placeholder="Search by name...">
      <button type="submit">Search</button>
   </form>

   <% if (locals.noResults) {  %>
      <p>Couldn't find that user in the Database. Maybe try again?</p>
      <p>Or go back to <a href="/">Home</a>?</p>
      <% } else if (users && users.length > 0) { %>
      <ul>
         <% users.forEach(user => { %>
            <li>
               ID: <%= user.id %>, Name: <%= user.firstName %> <%= user.lastName %>, Email: <%= user.email %>, Age: <%= user.age %>, Bio: <%= user.bio %>
               <a href="/<%= user.id %>/update">Update</a>
                 <form action="/<%= user.id %>/delete" method="POST" style="display:inline;">
                    <button type="submit" onclick="return confirm('Are you sure you want to delete this user?');">Delete</button>
                  </form>
            </li>
         <% }); %>
   </ul>
   <% } else { %>
   <p>No users found.</p>
   <% } %>   
     <a href="/create">Create a user</a>
</body>
</html>

